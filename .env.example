# ⚠️  NUNCA commitear .env.local — está en .gitignore.
# Este archivo es sólo de referencia. Copia a .env.local y rellena los valores.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY sólo se usa en server actions y webhooks (NUNCA en cliente).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── URLs ─────────────────────────────────────────────────────────────────────
# Local: http://localhost:3000  |  Producción: definir en Vercel env vars
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://barberiaos.com

# ── Stripe Billing (test mode) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# ── BarberíaOS Shield / Security Audit Microservice ──────────────────────────
# server-side only — NUNCA usar prefijo NEXT_PUBLIC
# Local: http://localhost:8001  |  Prod: Railway, Fly.io, etc.
SECURITY_AUDIT_SERVICE_URL=http://localhost:8001

# ── IA del Dueño ─────────────────────────────────────────────────────────────
# server-side only — NUNCA usar prefijo NEXT_PUBLIC
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Email de confirmación de reservas (Resend) ────────────────────────────────
# server-side only — NUNCA usar prefijo NEXT_PUBLIC
# 1. Crear cuenta en https://resend.com (plan gratuito: 100 emails/día)
# 2. Crear API key en Resend → API Keys → Create API Key
# 3. Verificar tu dominio en Resend → Domains (necesario para producción)
# Sin esta variable, el email no se envía pero las reservas siguen funcionando.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Remitente del email de confirmación. Debe ser un dominio verificado en Resend.
# Ejemplo: "BarberíaOS <reservas@barberiaos.com>"
RESEND_FROM_EMAIL=BarberíaOS <reservas@barberiaos.com>

# ── Cron de recordatorios 24h (Vercel Cron) ──────────────────────────────────
# server-side only — NUNCA usar prefijo NEXT_PUBLIC
# Protege el endpoint /api/internal/cron-reminders
# Genera un secreto aleatorio: openssl rand -hex 32
CRON_SECRET=secreto_muy_largo_y_seguro

# ── SEO / Verificación Google ────────────────────────────────────────────────
# 1. Ve a https://search.google.com/search-console
# 2. Añadir propiedad → Prefijo de URL → https://www.barberiaos.com/
# 3. Verificar con etiqueta HTML → copia el valor "content" de la meta tag
# 4. Pega aquí ese valor y haz deploy → vuelve a Search Console y haz clic en Verificar
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── IndexNow (Bing / Yandex / Yep) ──────────────────────────────────────────
# Clave ya generada y archivo público en /public/1305b275734041b0a1b6b923fa37229a.txt
# No tocar — el workflow n8n ya la usa hardcodeada.
# INDEXNOW_KEY=1305b275734041b0a1b6b923fa37229a

# ── n8n Automations ─────────────────────────────────────────────────────────
# server-side only — NUNCA usar prefijo NEXT_PUBLIC
#
# N8N_WEBHOOK_URL: URL de producción del webhook en n8n (NO la Test URL, NO localhost).
#   - Si está vacío → /api/internal/automation-events/dispatch retorna 500.
#   - Genera esta URL en n8n → Workflows → tu flujo → Webhook → Production URL.
#   - Los flujos wf1–wf4 en /n8n-workflows/ son los que deben estar publicados.
#   - IMPORTANTE: los archivos JSON en /n8n-workflows/ tienen claves hardcodeadas
#     (SUPABASE_SERVICE_ROLE_KEY, OPENAI_API_KEY). En n8n de producción deben
#     reemplazarse por variables de entorno del workflow.
#
# N8N_WEBHOOK_SECRET: secreto compartido para autorizar llamadas n8n ↔ BarberíaOS.
#   - Se pasa como header "x-n8n-secret" o "Authorization: Bearer <secret>".
#
# ⚠️  NO usar Google Indexing API para páginas normales — está reservada para
#     JobPosting y BroadcastEvent (datos estructurados). Para indexar páginas usa:
#     1. sitemap.xml dinámico (ya generado en /sitemap)
#     2. robots.txt correcto (ya en /robots)
#     3. IndexNow: clave en /public/1305b275734041b0a1b6b923fa37229a.txt
#     4. Submit manual en Search Console o ping de sitemap desde n8n.
N8N_WEBHOOK_URL=https://your-n8n-domain.com/webhook/barberiaos-events
N8N_WEBHOOK_SECRET=change_me
