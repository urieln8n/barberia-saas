# ⚠️  NUNCA commitear .env.local — está en .gitignore.
# Este archivo es sólo de referencia. Copia a .env.local y rellena los valores.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY sólo se usa en server actions y webhooks (NUNCA en cliente).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── URLs ─────────────────────────────────────────────────────────────────────
# Local: http://localhost:3000  |  Producción: definir en Vercel env vars
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://barberiaos.com

# ── Stripe Billing (test mode) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# ── BarberíaOS Shield / Security Audit Microservice ──────────────────────────
# server-side only — NUNCA usar prefijo NEXT_PUBLIC
# Local: http://localhost:8001  |  Prod: Railway, Fly.io, etc.
SECURITY_AUDIT_SERVICE_URL=http://localhost:8001

# ── IA del Dueño ─────────────────────────────────────────────────────────────
# server-side only — NUNCA usar prefijo NEXT_PUBLIC
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── n8n Automations ─────────────────────────────────────────────────────────
# server-side only — NUNCA usar prefijo NEXT_PUBLIC
# Usar la Production URL del webhook de n8n, no la Test URL ni localhost.
N8N_WEBHOOK_URL=https://your-n8n-domain.com/webhook/barberiaos-events
N8N_WEBHOOK_SECRET=change_me
# Alternativa legacy si ya existe en infraestructura:
# WEBHOOK_SECRET=change_me
